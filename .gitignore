# Personal/sensitive config (not tracked)
.gitconfig.local
.zshrc.local

# Lazygit runtime state (contains recent repo paths)
lazygit/.config/lazygit/state.yml

# Karabiner auto-generated files (only track assets/complex_modifications/)
karabiner/.config/karabiner/karabiner.json
karabiner/.config/karabiner/automatic_backups/

# Yazi backup files
yazi/.config/yazi/*.toml-*

# OS
.DS_Store

# Editor
*.swp
*~
